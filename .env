# Port sur lequel le serveur Node.js va écouter (3000 par défaut sur Render)
PORT=10000

# Clé de sécurité pour authentifier les requêtes provenant de ton PHP
# Doit correspondre à la valeur 'node_api_key' dans ta base de données ou getenv('NODE_API_KEY')
NODE_API_KEY=9e5c583fbfec8beadde1b006d235eb39

# URL de ton SaaS PHP (utilisée pour renvoyer les messages via Webhook)
# Exemple: https://ton-saas-wa.com/webhook/whatsapp
APP_URL=https://wisedesign.pro/wabaperso

# Niveau de log (silent, error, info, debug)
# Baileys peut être bavard, 'error' ou 'silent' est recommandé pour la prod
LOG_LEVEL=error
